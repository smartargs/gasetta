# supabase/.env.example — Copy to .env. NEVER commit .env*.
# These are the secrets Edge Functions read at runtime.
#
# In production: set via `supabase secrets set --env-file .env`. The Supabase
# platform auto-injects SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY for deployed
# functions, so you only really need to set the ones below.

GITHUB_TOKEN=

# OpenAI — used by the summarize function. The cheap mini for per-item
# summaries + releases, the proper 4o for the daily org-digest synthesis.
OPENAI_API_KEY=

# Optional model overrides (defaults are fine).
# OPENAI_MODEL_ITEM=gpt-4o-mini
# OPENAI_MODEL_RELEASE=gpt-4o-mini
# OPENAI_MODEL_ORG=gpt-4o

# Optional summarize caps (defaults: 50 items per invocation, 20 releases).
# SUMMARIZE_ITEM_LIMIT=50
# SUMMARIZE_RELEASE_LIMIT=20

# Cadence: per-item summaries run every day; the editorial org_digest is
# synthesized once a week on this UTC weekday (0=Sun..6=Sat, default 1=Mon).
# Override per-invocation with ?digest=true or ?digest=false on the URL.
# GASETTA_PUBLISH_DAY=1

# Force the org_digest on/off regardless of day (one-off override).
# SUMMARIZE_ORG_DIGEST=true

# Bounded parallelism for per-item + release summaries.
# Default 5 keeps us under OpenAI Tier 1 rate limits (~60-80 RPM with our
# average prompt size). Higher tiers can safely raise it; Tier 1 should not.
# SUMMARIZE_CONCURRENCY=5

# Optional overrides (defaults are fine for first deploy)
GASETTA_ORG=neo-project
GASETTA_BOOTSTRAP_DAYS=30
GASETTA_MAX_REPOS_PER_RUN=60

# Bounded parallelism across repos during ingest. GitHub's quota is 5000
# requests/hour total — concurrency is bounded by hourly volume, not RPS.
# 5 is safe for the neo-project org; tune up with larger token budgets.
# Calls *within* one repo stay serial regardless (see ingestOneRepo).
# INGEST_REPO_CONCURRENCY=5

# NOTE: do NOT put SUPABASE_URL or SUPABASE_SERVICE_ROLE_KEY in this file —
# the CLI strips any SUPABASE_* var (with a warning) because those are
# platform-reserved and auto-injected by the runtime. Locally they come from
# the running `supabase start` stack; on the deployed platform they're set
# automatically. You only need them in env files if you're running the
# function against a *remote* Supabase from a non-Supabase host, which isn't
# how Edge Functions normally run.
